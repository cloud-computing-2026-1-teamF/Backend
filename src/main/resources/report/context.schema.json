{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanggwon.ai/report/context.schema.json",
  "title": "ReportContext",
  "description": "미니-RAG 입력. 백엔드(Kotlin)가 AnalysisRecommendationDto + 가정값 + 사전 계산치를 조립해 LLM user 메시지로 전달한다. 모든 금액 단위는 원(KRW). DTO 매핑은 각 필드 description 참고.",
  "type": "object",
  "required": ["meta", "location", "costs", "market", "assumptions", "derived"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["analysisId", "region", "businessType", "transactionType"],
      "additionalProperties": false,
      "properties": {
        "analysisId": { "type": "string", "description": "AnalysisEntity.id" },
        "region": { "type": "string", "description": "AnalysisEntity.region (행정동 표시명)" },
        "businessType": {
          "type": "object",
          "required": ["key", "label"],
          "properties": {
            "key": { "type": "string", "description": "AnalysisEntity.businessTypeKey (예: cafe)" },
            "label": { "type": "string", "description": "BusinessType.label (예: 카페)" }
          }
        },
        "transactionType": { "type": "string", "description": "rec.transactionType (월세/전세/매매)" },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vacancyId": { "type": "string", "description": "rec.vacancyId" },
        "roadAddress": { "type": ["string", "null"], "description": "rec.roadAddress" },
        "areaId": { "type": "string", "description": "rec.areaId" },
        "latitude": { "type": "number", "description": "rec.latitude" },
        "longitude": { "type": "number", "description": "rec.longitude" },
        "distanceM": { "type": "integer", "description": "rec.distanceM (분석 중심으로부터 거리)" },
        "facilityTotalSizeM2": { "type": ["number", "null"], "description": "rec.facilityTotalSize (㎡)" }
      }
    },
    "costs": {
      "type": "object",
      "description": "전부 원(KRW). DTO Long 값이 만원 단위면 백엔드 조립 단계에서 ×10000 정규화 필요(README 참고).",
      "additionalProperties": false,
      "properties": {
        "depositKrw": { "type": ["integer", "null"], "description": "rec.deposit" },
        "monthlyRentKrw": { "type": ["integer", "null"], "description": "rec.monthlyRent" },
        "maintenanceFeeKrw": { "type": ["integer", "null"], "description": "rec.maintenanceFee" },
        "premiumKrw": { "type": ["integer", "null"], "description": "rec.premium (권리금)" },
        "salePriceKrw": { "type": ["integer", "null"], "description": "rec.salePrice (매매가)" }
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": { "type": "number", "description": "rec.score (입지 점수 0~100)" },
        "estMonthlyRevenueKrw": { "type": ["integer", "null"], "description": "프론트 rev(만원)을 원으로 정규화. 이 매물의 추정 월매출" },
        "areaAvgSalesPerStoreKrw": { "type": ["integer", "null"], "description": "rec.averageSalesPerStore (지역 평균 점포 매출)" },
        "footTrafficDaily": { "type": ["integer", "null"], "description": "프론트 foot. 일평균 유동인구" },
        "footHourly": {
          "type": ["array", "null"],
          "description": "rec.hourlyFloatingPopulation. 길이 24 (00~23시)",
          "items": { "type": "number" },
          "minItems": 24,
          "maxItems": 24
        },
        "floatingPopulationAnnualTotal": { "type": ["integer", "null"], "description": "rec.floatingPopulationAnnualTotal" },
        "competitorCount500m": { "type": ["integer", "null"], "description": "프론트 comp. 반경 500m 동종 경쟁점 수" },
        "restaurantCount500m": { "type": ["integer", "null"], "description": "rec.restaurantCount500m" },
        "cafeCount500m": { "type": ["integer", "null"], "description": "rec.cafeCount500m" },
        "industryGrowthRatePct": { "type": ["number", "null"], "description": "프론트 growth. rec.industryGrowthRate500m (%)" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subwayStationInfo": { "type": ["string", "null"], "description": "rec.subwayStationInfo" },
        "busStopInfo": { "type": ["string", "null"], "description": "rec.busStopInfo" },
        "parkingInfo": { "type": ["string", "null"], "description": "rec.parkingInfo" }
      }
    },
    "competitors": {
      "type": "array",
      "description": "주변 동종업종 경쟁점 + 네이버 리뷰 스니펫. scraper(Playwright)의 naver_data.db -> reviews_cache.json 에서 매물 좌표/업종으로 선별. 리뷰 본문 텍스트 기반(태그 아님).",
      "items": {
        "type": "object",
        "required": ["name", "reviewSnippets"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "restaurants.name" },
          "category": { "type": ["string", "null"], "description": "restaurants.category" },
          "distanceM": { "type": ["integer", "null"], "description": "매물~경쟁점 거리(haversine)" },
          "reviewCount": { "type": ["integer", "null"], "description": "restaurants.review_count" },
          "reviewSnippets": { "type": "array", "items": { "type": "string" }, "description": "reviews.content 일부 (매물당 3~5개, 각 200자 이하 권장)" }
        }
      }
    },
    "assumptions": {
      "type": "object",
      "description": "app.report.* 설정값. 데이터에 없는 비용 항목의 표준 가정. disclaimers에 반드시 노출.",
      "required": ["cogsRatio", "laborCostMonthlyKrw", "avgTicketPriceKrw", "interiorSetupCostKrw", "operatingDaysPerMonth", "peakShareOfDailySales"],
      "additionalProperties": false,
      "properties": {
        "cogsRatio": { "type": "number", "description": "원가율 (0~1). 예: 0.35" },
        "laborCostMonthlyKrw": { "type": "integer", "description": "월 인건비 가정" },
        "avgTicketPriceKrw": { "type": "integer", "description": "객단가 가정" },
        "interiorSetupCostKrw": { "type": "integer", "description": "인테리어·설비 초기비 가정" },
        "operatingDaysPerMonth": { "type": "integer", "description": "월 영업일수 가정" },
        "peakShareOfDailySales": { "type": "number", "description": "피크 시간대가 일매출에서 차지하는 비중 (0~1)" },
        "peakHoursPerDay": { "type": "integer", "description": "피크 시간 길이(시간). 예: 3" }
      }
    },
    "derived": {
      "type": "object",
      "description": "백엔드가 결정적으로 계산. LLM은 재계산 금지, 값 그대로 인용. 산식은 README 참고.",
      "required": ["initialInvestmentKrw", "monthlyFixedCostKrw", "monthlyCogsKrw", "monthlyNetProfitKrw", "roiMonths", "bep", "target"],
      "additionalProperties": false,
      "properties": {
        "initialInvestmentKrw": { "type": "integer", "description": "보증금 + 권리금 + 인테리어비" },
        "monthlyFixedCostKrw": { "type": "integer", "description": "월세 + 관리비 + 인건비" },
        "monthlyCogsKrw": { "type": "integer", "description": "추정월매출 × 원가율" },
        "monthlyNetProfitKrw": { "type": "integer", "description": "추정월매출 − 고정비 − 변동비" },
        "roiMonths": { "type": "number", "description": "초기투자금 ÷ 월 순이익" },
        "bep": {
          "type": "object",
          "description": "손익분기(순이익 0) 기준",
          "properties": {
            "monthlyRevenueKrw": { "type": "integer", "description": "고정비 ÷ (1 − 원가율)" },
            "dailyRevenueKrw": { "type": "integer", "description": "BEP월매출 ÷ 영업일수" },
            "peakUnitsPerDay": { "type": "integer", "description": "BEP 일매출 × 피크비중 ÷ 객단가" }
          }
        },
        "target": {
          "type": "object",
          "description": "추정매출 달성 기준",
          "properties": {
            "dailyRevenueKrw": { "type": "integer" },
            "peakUnitsPerDay": { "type": "integer" }
          }
        }
      }
    }
  }
}
